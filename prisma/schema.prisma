// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  //engineType      = "library"
  //  engineType="binary"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

//libros fisicos

model Category {
  id            String         @id @default(cuid())
  name          String         @unique
  physicalBooks PhysicalBook[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

model Author {
  id            String         @id @default(cuid())
  name          String
  physicalBooks PhysicalBook[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

model PhysicalBook {
  id                String          @id @default(cuid())
  isbn              String?         @unique
  title             String
  authorId          String
  categoryId        String
  pnf               Pnf?
  yearOfPublication Int
  editorial         String?
  totalStock        Int
  availableStock    Int
  status            BookStatus      @default(DISPONIBLE)
  author            Author          @relation(fields: [authorId], references: [id])
  category          Category        @relation(fields: [categoryId], references: [id])
  operations        BookOperation[]
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
}

model BookOperation {
  id             String        @id @default(cuid())
  bookId         String
  type           OperationType
  quantity       Int
  observations   String?
  personId       String?
  personNames    String
  personSurNames String
  book           PhysicalBook  @relation(fields: [bookId], references: [id])
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@index([bookId, createdAt])
}

enum BookStatus {
  DISPONIBLE
  AGOTADO
  MANTENIMIENTO
}

enum Pnf {
  INFORMATICA
  ELECTRONICA
  CONTADURIA
  ADMINISTRACION
  ELECTRICIDAD
  MECANICA
  INSTRUMENTACION
  TELECOMUNICACIONES
}

enum OperationType {
  ENTRADA
  PRESTAMO
  DEVOLUCION
  BAJA
  AJUSTE
}

//usuarios,roles y libros guardados xd

model User {
  id       Int         @id @default(autoincrement())
  email    String      @unique
  name     String
  password String
  role     Role        @default(USER)
  saves    SavedBook[]
}

enum Role {
  USER
  ADMIN
  SUPERADMIN
}

model Book {
  id          Int         @id @default(autoincrement())
  title       String
  description String?
  routepdf    String
  routeimg    String?
  createAt    DateTime    @default(now())
  updateAt    DateTime    @updatedAt
  savedby     SavedBook[]
}

model SavedBook {
  id      Int      @id @default(autoincrement())
  saveeAt DateTime @default(now())

  book   Book @relation(fields: [bookId], references: [id]) // Cambiado a singular
  bookId Int

  user   User @relation(fields: [userId], references: [id])
  userId Int

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, bookId])
}

//inventario

model UserInventory {
  id       Int    @id @default(autoincrement())
  name     String
  lastname String
  cedula   Int
  loans    Loan[]
}

model Item {
  id          Int     @id @default(autoincrement())
  name        String
  description String?
  stock       Int
  routeimg    String?
  loans       Loan[]
}

model Loan {
  id       Int @id @default(autoincrement())
  quantity Int @default(1)

  userinventory   UserInventory @relation(fields: [userInventoryId], references: [id])
  userInventoryId Int

  item   Item @relation(fields: [itemId], references: [id])
  itemId Int
}
