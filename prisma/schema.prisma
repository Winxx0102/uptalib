generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

//usuarios,roles y libros guardados xd

model User {
  id    Int     @default(autoincrement()) @id
  email String  @unique
  name  String 
  password String
  role Role @default(USER)
  saves SavedBook[]
}

model Books{
id Int @default(autoincrement()) @id
title String
description String?
routepdf String
routeimg String?
createAt DateTime @default(now())
updateAt DateTime @updatedAt
savedby SavedBook[]

}

model SavedBook{
id Int @default(autoincrement()) @id
saveeAt DateTime @default(now())

books    Books   @relation(fields: [bookId], references: [id])
bookId  Int

  user    User     @relation(fields: [userId], references: [id])
  userId  Int


 @@unique([userId, bookId])

}

enum Role{
USER 
ADMIN
SUPERADMIN
}


//inventario

model UserInventoy {
  id    Int    @id @default(autoincrement())
  name  String
  lastname String
  cedula Int
  loans Loan[]
}

model Item {
  id       Int    @id @default(autoincrement())
  name     String 
  description String?
  stock    Int   
  loans    Loan[]
}

model Loan {
  id       Int  @id @default(autoincrement())
  quantity Int  @default(1) 
  
  userinventory  UserInventoy @relation(fields: [userInventoryId], references: [id])
  userInventoryId   Int

  item     Item @relation(fields: [itemId], references: [id])
  itemId   Int
}


